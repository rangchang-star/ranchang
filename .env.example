# Supabase Configuration (可选，用于存储和认证)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# PostgreSQL Database Configuration (必需 - 阿里云 RDS)
# 格式：postgresql://用户名:密码@主机地址:端口/数据库名
DATABASE_URL=postgresql://postgres:your_password@your_host:5432/ran_field
